        cout << "invalid input\n";
        cin >> age;
    }

    cout << "Enter yout age in months " ;
    while(!(cin >> month)){
        cout <<"invalid input\n";
        cin >> month;
    }

    while (month < 0 || month >= 12){
        cout << "Invalid input\n";
