#include <iostream>
#include <iomanip>
using namespace std;

int main(){
    int num_1, num_2, code;
    double Answer;
    cout << "Enter first numbers: ";

    while (!(cin >> num_1)){
        cout << "invalid input, try again ";
        cin >> num_1;
    }

    cout << "Enter second numbers: ";
    while (!(cin >> num_2)){
        cout <<" invalid input, try again ";
        cin >> num_2;
    }

    cout<<"Enter the operation code: \n"
        <<"1:Sum\n"
        <<"2:Deduction\n"
        <<"3:Production\n"
        <<"4:Division\n"
        <<"Enter integer code: ";

    while (!(code < 1 || code > 4 )){
        cout << "Please re-enter Operation code: " ;
        cin >> code ;
    }

    switch (code)
    {
        case 1: 
            Answer = num_1 + num_2;
        break;

        case 2: 
            Answer = num_1 - num_2;
        break;

        case 3:
            Answer = num_1 * num_2;
        break;

        case 4 :
            while (num_2 == 0){
                cout << "The divisor cannot be 0 ";
                cout << "Reenter again";
                cin >> num_2;
            }
                Answer = num_1 / num_2;
            }
    }
        cout << "The first numeber: " << num_1 << "\n" 
             << "The seconde number: " << num_2 << "\n" 
             << "Interger code " << code << "\n"
             << "Result: " << Answer << "\n";

            return 0;

}
