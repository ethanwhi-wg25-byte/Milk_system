#include <iostream>
#include <iomanip>
using namespace std;

int main(){
    double income;
    cout << "What is your income? :Rm";
    cin >> income;

    if (income < 1000){
        income *= 1.2;
    }

    else if  (income < 2000){
        income *= 1.3;
    }

    else {
       income *= 1.24;
    }
    
    cout << fixed << setprecision(2) 
         << "The total tax is Rm" << income << "\n";
    return 0;
}