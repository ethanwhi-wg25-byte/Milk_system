#include <iostream>
#include <iomanip>
using namespace std;

int main(){
    double salary;
    cout << "Enter your monthly salary $";
    cin >> salary ;
    
    while (salary < 0){
        cout << "Salary could not be negative\n";
        cout << "Reenter your salary" ;
        cin >> salary;
    }

    if (salary < 1000){
            salary += 100;
        }
    else if (salary <=3000 ){
            salary +=200;
        }
        else {
            salary +=300;
        }
       
    cout << "Your new salary will be $" << salary << "\n";
    return 0;
}