#include <iostream>
using namespace std;

int main(){
    
    double r ,area, circumference;
    const double pi = 3.1415927;

    cout << "Enter your radius: ";
    cin >> r;

    area = pi* r * r;
    circumference = 2 * pi * r;

    cout << "Area = " << area << endl
         << "Circumference = " << circumference ;

    return 0;
}

