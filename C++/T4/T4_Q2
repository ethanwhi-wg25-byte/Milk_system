//input = opening balance , deposits , withdrawals
//process = += , -=
//output = closing balance

#include <iostream>
#include <iomanip>
using namespace std;

int main(){
    double balance ,deposit ,withdrawals;

    cout << " Enter your amount of your opening balance :Rm";
    cin >> balance;

    cout << " Enter the amount of deposit into your account:Rm ";
    cin >> deposit;

    cout << " Enter the amount of withdrawals from the account during last month:Rm ";
    cin >> withdrawals;

    balance += deposit;
    balance -= withdrawals ;
  

    cout << fixed << setprecision(2) << " Your current balance is : Rm" << balance ;
    return 0;
 }