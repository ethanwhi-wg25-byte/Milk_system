#include <iostream>
#include <cmath>
#include <cctype>
using namespace std;

int main (){
    char option, sure ;
    double num, num2, answer ;


    do {
    cout << endl << "\tSELECT OPTION TO CALCULATE: " << endl
        << "\t============================" << endl
        << "\t[S] square of a number" << endl
        << "\t[Q] squareroot of a number " << endl
        << "\t[P] X power of Y " << endl
        << "\t[F] Factorial of number" << endl
        << "\tPress [E] to exit the program " <<endl
        << endl << "Enter option>> " ; 
            cin >> option ;
             option = toupper(option);

        while (option != 'S' && option != 'P' && option != 'Q' && option != 'E' && option != 'F'){
            cout << endl << "Options are S, Q, P , F or E only." << endl 
                 << "Please reenter option : " ;
            cin >> option ;
             option = toupper(option);
        }



        if (option == 'S'){
            cout << "\tsquare of a number" << endl 
                 << "\t-----------------------" << endl
                 << "Please enter a number : " ;
            cin >> num ;

            answer = num * num;
            cout << endl << "Sqaure of " << num << ": " << answer << endl;
        }


            if (option == 'Q' ){
                cout << "\tsqaure root of a number " << endl
                     << "\t-------------------" << endl
                     << endl << "Please enter a number : " ;
                     cin >> num;

            answer = sqrt(num);
            cout << endl << "Sqaureroot of " << num << ": " << answer << endl;
        }


            if (option == 'P'){
                cout << endl << "\tX Power of Y" << endl
                     <<         "\t------------" << endl
                     << "Please enter a number : " ;
                cin >> num; 

                cout << "Please enter the power index : " ;
                cin  >> num2;


            answer = pow ( num, num2);

            cout << num << " power of " << num2 <<": " << answer << endl;

            }

            if ( option == 'F'){
                cout << endl << "\tFactorised of a number " << endl
                     <<         "\t-----------------------" << endl    
                     << "Please enter a number "  ;
                cin >> num ;

                int F_answer = 1;
                for (int i =1; i <= num; i++){
                    F_answer *= i;
                }

                cout << "Factorial of " << num << ": " << F_answer << endl;
            }

            if (option == 'E'){
                cout << " Are you sure you want to end? (Y/N): " ;
                cin >> sure;
                sure = toupper(sure);

                if (sure == 'Y') {
                    cout << "Program ends now......" << endl;
                    return 0;
                }

                
            }
    
    }while (true);

        return 0;
    }




