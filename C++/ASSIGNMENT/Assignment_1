#include <iostream>
#include <iomanip>
#include <cmath>
using namespace std;

int main (){
    const double R = 4.50;
    double M, 
           T,
           V,
           V_max = 0,
           V_low = 99999,
           range ;
    int counter = 0; 


    do {
        cout << "Enter weight of the ship, M (metric tons) : ";
        (!(cin >> M));
        if (M < 1 ){
            cout << "Weigt of the ship , M must be more than 0!" << endl;
        }
    } while ( M < 1 );


    do {
        cout << "Enter constant propeller thurst , T (Kilonewtons): ";
        (!(cin >> T)) ;
        if(T <1){
            cout << "constant propeller thurst, T must be more than 0! "<< endl;
        }
    } while (T < 1 );
    
    
   cout << left << setw(40) << "Distance" 
        << right << setw(25) << "Ship's velocity" << endl
        << left << setw(40) << "(Distance)" 
        << right << setw(25) << "(meters per second)" << endl;



    for (double S = 3.0; S <= 10.00 ; S += 0.5) {
        V = sqrt( T / R)*(1.0 - exp(-9.00* S / M));

            if ( V > V_max ){
            V_max = V;
            }
            if ( V_low > V ){
            V_low = V;
            }
            range = V_max - V_low;
        
        cout << fixed << setprecision(2) << right << setw(7) << S 
             << setw(55) << setprecision(3) << V << endl;
    }
    cout << endl << "-----------------------------------------------------------------" ;
    cout << endl << "The maximum possibe spped for the ship is " << V_max << "m/s" << endl;
    cout << endl << "The lowest possible speed for the ship is " << V_low << "m/s" << endl;
    cout << endl << "The range between maximum and lowest possible speed is " << range << "m/s" << endl;
    cout << "-----------------------------------------------------------------" ;
}