#include <iostream>
#include <iomanip>
using namespace std;

int main()
{
    int grade[10];
    int quiz;
    double sum = 0, average;
    bool found = 0;
   
    const int NUM_QUIZZES = 10;
    const int MIN_GRADE = 90;
    
    int bigScore = 0;
    int quizNumber = 0;

    cout << " Please enter " << NUM_QUIZZES << " integer quiz grade." << endl << endl;
    
    for (quiz = 0; quiz < NUM_QUIZZES; ++quiz)
    {
        cout << "Enter grade for quiz " << quiz + 1 << ": ";
        cin >> grade[quiz];
    }

    for (quiz = 0; quiz < NUM_QUIZZES; ++quiz)
    {
    	if (grade[quiz] >= MIN_GRADE)
    	{
    		found = 1;
    		bigScore = grade [quiz];
    		quizNumber = quiz+1;
    		break; 
		}
	}
   
	if (found == 0)
	{
	cout << endl << "No grade greater than " << MIN_GRADE << " was found." << endl;
	}
	else 
	{
	cout << endl << "The first grade of at least " << MIN_GRADE << " is:" << endl << endl;
        cout << "Quiz #" << quizNumber << "  Grade: " << setw(3) << bigScore << endl;
	}
    system("pause");
}