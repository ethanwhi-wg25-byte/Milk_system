#include <iostream>
using namespace std;
 int main(){

    int num;
    while(true){
        cout << "Enter your number of interger: ";
        cin >> num;
        if( num < 1 || num > 300){
         
          cout << "Cannot be less than 1 or greater than 300" << endl;
          cout << "please type again" << endl;

        }else{
             break;
        }

        
    }
    
    
    
    int array[num], value;
    for(int i = 0; i < num; i++){
        cout << "Enter your value" << i+1 << ": ";
        cin >> value ;
        array[i] = value;
    }
    int maxim = array[0], th = 1 ;
    for(int m = 1; m < num; m++){
        if(array[m] > maxim){
            maxim = array[m];
            th = m+1;
        }
    }

    int total = 0;
    for(int i=0; i<num; i++){
        total += array[i];
    }

    double average = total / num;

    int count=0;
    for(int i = 0; i < num ; i++){
        if(array[i] > average){
        count++;
        }
    }

    cout << "Maximun: " << maxim << endl 
         << "It is " << th << "th value " << endl
         << "Average: " << average << endl
         << "It has " << count << " value above the average";

}
