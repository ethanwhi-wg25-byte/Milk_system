#include <iostream>
#include <thread>
#include <chrono>
#include <iomanip>
#include <limits>
#include "yes.h"

using namespace std;


void detectmaterial();


int main (){

    int received = -1 ;
    int n ;

    double x_ton[100];  
    bool detection = true;

 
    do{
        if(detection){
            detectmaterial();
            detection = false;
        }

        cout << "Raw material received?"<< endl << "(1 = Yes, 0 = No): " ;
    
        if (!(cin >> received)){
            cout << "Invalid Choice, Enter 0 OR 1 ONLY: ";
            cin.clear();
            cin.ignore();  
            detection = false;
            continue;
        }

        if (received == 1){
            cout << endl << "System is now running" << endl
                 << "How many batch milk received?: ";
            cin >> n;

        //Enter How many Batch
        for (int i = 0; i < n ; i++){
            cout << "Enter Batch " << i +1 << " Weight (ton): " ;
            cin >> x_ton[i];

            cout << "Analyzing " << " batch " << i + 1 << ": ";
            
                //animation loading bar
                for (int i = 1; i <= 3; i++) {
                    cout << "#" << flush;
                    this_thread::sleep_for(chrono::seconds(1));
                    }
                MilkProcessor Processor;
                Processor.processRawMaterial(x_ton[i]);
            }

        }
            else if (received == 0){
                cout << "No raw material yet, checking again" << endl;
                detection = true;
                continue;

            }
                else{
                    cout << "Invalid choice , please enter 0 or 1"; 
                    received = -1;
                    detection = false;
                }
    
    }while (received != 1 );

    
    
    
}


void detectmaterial(){
        cout << endl << "Detecting raw material[";
        for (int i = 1; i < 5 ; i++){
            cout << "#" << flush;
            this_thread :: sleep_for(chrono ::seconds(1));
        }
        cout <<"]" << endl;
    }

