#include <iostream>
#include <cmath>
using namespace std;

int main() {
    cout << "Fahrenheit\tCelsius" << endl;
    cout << "--------------------" << endl;

    for (int fahrenheit = 20; fahrenheit <= 100; fahrenheit += 5) {
        double celsius = (fahrenheit - 32) * 5.0 / 9.0;
        int celsiusRounded = static_cast<int>(round(celsius));

        cout << fahrenheit << "\t\t" << celsiusRounded << endl;
    }

    cout << "--------------------" << endl;
    return 0;
}