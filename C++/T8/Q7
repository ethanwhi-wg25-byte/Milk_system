#include <iostream>
#include <iomanip>
#include <cmath>
using namespace std;
int main (){
    cout << fixed << setprecision(2)
         << left << setw(8) << "v/c" << "m/m0" << endl;

    for (double r = 0.2; r <= 0.9 + 1e-9; r += 0.1) {
        double ratio = 1.0 * sqrt(1.0 - pow(r,2));
        cout << setw(8) << r << ratio << endl;
    }
return 0;
}