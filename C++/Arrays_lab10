#include <iostream>
#include <iomanip>
using namespace std;

int main(){

    const int C_interger_array = 100;
    int interger_array[C_interger_array];
    int sum = 0;
    double average =0.0;
    cout << "Please enter 10 integer quiz grades."<< endl;

    for(int i = 0; i < C_interger_array; i++){
        cout << "Enter grade for quiz " << i+1 << ": ";
        cin >> interger_array[i];
        sum += interger_array[i];
    }

    cout << "The grade you entered are : " ;
    for(int i = 0; i < C_interger_array; i++){
        cout << setw(4) << interger_array[i]<<" ";
    }

        average = sum /C_interger_array;
    

    cout << endl << "The average quiz grade is " << average << "\n";

}