#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
Council Agent System — MVP (paper trading)

Implements Algorithm 1-style loop:
- Collect agent verdicts
- Judge consensus
- MIN_CONFIDENCE gate
- PhilosophyGuardian gate (Five Iron Laws)
- Cooling period gate
- Execute (paper)

Design goals:
- Deterministic, auditable, low action-rate by default.
"""

from __future__ import annotations

import argparse
import dataclasses
import json
import math
import os
import random
import time
