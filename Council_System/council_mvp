# -----------------------------
# Domain models
# -----------------------------
class Action(str, Enum):
    LONG = "LONG"
    SHORT = "SHORT"
    HOLD = "HOLD"


@dataclass
class MarketSnapshot:
    symbol: str
    ts: int
    price: float
    ohlcv: List[Tuple[int, float, float, float, float, float]]  # (ts, o, h, l, c, v)


@dataclass
class Verdict:
    agent: str
    action: Action
    confidence: float  # 0..1
    rationale: str
    size_hint: float = 1.0  # relative suggestion (0..1)


@dataclass
class Consensus:
    action: Action
    confidence: float
    agree_count: int
    total_agents: int
    agreement_ratio: float
    notes: List[str]
    raw: List[Verdict]


@dataclass
class IronLaws:
    MAX_LEVERAGE: float = 10.0
    MAX_POSITION: float = 0.15          # fraction of equity
    STOP_LOSS_MODE: str = "server"      # require "server"
    MIN_CONFIDENCE: float = 0.75
    MIN_PROFIT_MULT: float = 3.0        # profit >= 3 * cost
    COOLING_PERIOD_SEC: int = 24 * 3600
    DAILY_TRADE_LIMIT: int = 3


@dataclass
class Fees:
    taker_fee: float = 0.0006  # 0.06% default (USDT-M taker)
    maker_fee: float = 0.0002  # 0.02%


@dataclass
class RiskConfig:
    initial_leverage: float = 1.0
    rr_target: float = 3.0
    max_drawdown_soft: float = 0.03
    max_drawdown_hard: float = 0.08
    vol_lookback: int = 30


@dataclass
class CouncilConfig:
    symbol: str = "BTC/USDT"
    timeframe_sec: int = 60
    candle_lookback: int = 120
    min_agents_agree: int = 4
    action_rate_soft_target: float = 0.05  # monitor only
    seed: int = 42


